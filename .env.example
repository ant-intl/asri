# ASRI Environment Configuration
# Copy this file to .env and fill in values

# Server Environment: local, dev, test, prod
SERVER_ENV=local

# Django Secret Key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key

# Database Configuration (not needed for local/SQLite)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=asri
# DB_USER=root
# DB_PASSWORD=

# Redis Configuration (for WebSocket channel layers)
# REDIS_URL=redis://127.0.0.1:6379/0

# LLM Provider Configuration
# LLM providers are configured via Admin page (http://127.0.0.1:8000/admin/),
# not through environment variables.

# Tracing Backend: noop (default), opentelemetry (requires plugin)
TRACING_BACKEND=noop
# TRACING_LOG_DIR=~/logs

# Skill storage root directory.
# Default: <project_root>/data/tenant/  (skills stored at data/tenant/{tenant_id}/skills/{skill_name}/)
# Set to a path outside the project to keep skills separate from code,
# e.g. ~/.asri for a home-directory layout shared across projects.
# ASRI_SKILLS_DIR=~/.asri
